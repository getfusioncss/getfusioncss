# =======================================================================
# GetFusionCSS - Official .gitignore
# =======================================================================

# Dependency directories (Framework dependencies)
node_modules/
jspm_packages/
.pnpm-store
.npm
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# System Files (OS specific)
.DS_Store
Thumbs.db
desktop.ini

# IDEs and Editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Optional Cache and Histories
.eslintcache
.stylelintcache
.node_repl_history
.cache/
.parcel-cache
.vite/

# Local Environment Files (Crucial for Security)
.env
.env.*
!.env.example

# NOTE: Do NOT add 'dist/' or 'dist' here. 
# Framework's compiled CSS/JS files inside dist/ MUST be pushed to GitHub 
# so that jsDelivr and unpkg CDNs can read and serve them.
